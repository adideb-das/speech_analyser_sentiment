# Picovoice (wake word detection)
PICOVOICE_API_KEY=your_key_here

# HuggingFace (pyannote diarization)
HUGGINGFACE_TOKEN=your_token_here

# Whisper model size: tiny, base, small, medium, large
WHISPER_MODEL=base

# Recording settings
SAMPLE_RATE=16000
CHUNK_DURATION=5

# Keywords to detect (comma-separated)
KEYWORDS=help,stop,emergency,hello,alert

# Output directory
OUTPUT_DIR=data/output

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
